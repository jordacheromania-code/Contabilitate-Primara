rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Check if the user is the owner of a company
    function isCompanyOwner(companyId) {
      return isSignedIn() && get(/databases/$(database)/documents/companies/$(companyId)).data.ownerId == request.auth.uid;
    }

    function isValidCompany(data) {
      return data.name is string 
        && data.name.size() <= 200
        && data.taxRegime in ['MICRO_1', 'MICRO_3', 'PROFIT_16']
        && data.vatPayer is bool
        && data.ownerId == request.auth.uid;
    }

    function isValidTransaction(data) {
      return data.amount is number 
        && data.type in ['INCOMING', 'OUTGOING']
        && data.date is string
        && data.userId == request.auth.uid
        && isCompanyOwner(data.companyId);
    }

    function isValidDocument(data) {
      return data.name is string 
        && data.status in ['PENDING', 'PROCESSED', 'ERROR']
        && data.userId == request.auth.uid
        && isCompanyOwner(data.companyId);
    }

    // 1. Companies
    match /companies/{companyId} {
      allow create: if isSignedIn() && isValidCompany(incoming());
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow update: if isOwner(resource.data.ownerId) && isValidCompany(incoming());
      allow delete: if isOwner(resource.data.ownerId);
    }

    // 2. Transactions
    match /transactions/{transactionId} {
      allow create: if isSignedIn() && isValidTransaction(incoming());
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) 
        && isValidTransaction(incoming()) 
        && incoming().companyId == existing().companyId;
      allow delete: if isOwner(resource.data.userId);
    }

    // 3. Documents
    match /documents/{documentId} {
      allow create: if isSignedIn() && isValidDocument(incoming());
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) 
        && isValidDocument(incoming())
        && incoming().companyId == existing().companyId;
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
